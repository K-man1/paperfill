# Copy to .env on the server and fill in real values. NEVER commit .env.
#   cp .env.example .env && nano .env

# Port gunicorn binds to. On Nest run `nest get-port` and paste the number here.
PORT=8080

# Flask session signing key. Generate one:  python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=

# LLM provider key. Points at any OpenAI-compatible API. Default base URL is
# the free Hack Club AI proxy (no card needed), so this is the only value you
# need to set to get started.
AI_API_KEY=
# Optional overrides — leave unset to use the Hack Club proxy defaults.
# AI_BASE_URL=https://ai.hackclub.com/proxy/v1
# AI_MODEL=qwen/qwen3-32b

# Answer-space detector. "deterministic" (default) = preprocess.py; set
# "multimodal" to route uploads through the vision + anchor-bridge path
# (multimodal_preprocess.py). Also selectable per-upload via the `detector`
# form field.
# PAPERFILL_DETECTOR=deterministic
# MULTIMODAL_MODEL=openai/gpt-4o   # vision model for the multimodal detector
# MULTIMODAL_INPUT=image           # "image" (render pages) or "pdf" (upload doc)
# MULTIMODAL_DPI=150               # render DPI when MULTIMODAL_INPUT=image

# Supabase — backs the admin dashboard (sign-ins, filled assignments, device
# count). Shared across all gunicorn workers so the numbers are consistent.
# SUPABASE_URL is the project URL; SUPABASE_SECRET_KEY is a *secret* API key
# (Supabase Dashboard → Project Settings → API keys → Secret keys, sb_secret_…).
# Keep it secret — it bypasses Row Level Security. NEVER put the real value
# here; this file is committed. Put it only in .env. If either is blank the
# dashboard just shows empty data; nothing else breaks.
SUPABASE_URL=https://oxpuwpeasjxasbhijeib.supabase.co
SUPABASE_SECRET_KEY=

# ---- Pro tier / Stripe billing ----
# Pro is sold via a Stripe Payment Link. To go live:
#   1. Stripe Dashboard → Payment Links → create a link for the Pro product
#      ($5/yr). Paste the URL below. The upgrade buttons go dark until it's set.
#   2. Stripe Dashboard → Developers → Webhooks → add an endpoint pointing to
#      https://<your-domain>/stripe/webhook, subscribe to
#      "checkout.session.completed", and paste its signing secret (whsec_…) into
#      STRIPE_WEBHOOK_SECRET. Without the secret the webhook rejects everything,
#      so paid users won't auto-upgrade (you can still grant Pro from /admin).
# The buyer's checkout email is matched to their account to flip is_pro, so the
# pricing page pre-fills it with the signed-in user's email.
STRIPE_PAYMENT_LINK=
STRIPE_WEBHOOK_SECRET=
# Display price on the pricing page (cosmetic only — set the real amount in Stripe).
# PRO_PRICE=$5/yr
