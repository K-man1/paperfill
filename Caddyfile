# PaperFill — Caddy reference for the Nest GATEWAY (not this app container).
#
# IMPORTANT: This block belongs in your Nest Caddyfile on the gateway shell
# (the `hackclub.app` host where the `nest` CLI lives), NOT inside the app's
# LXC container. The gateway already routes karman.hackclub.app to the
# container's gunicorn:8080 — this adds ww2explained.com to the same backend.
#
# The simplest correct move is to MIRROR your existing karman.hackclub.app
# entry and just add the new hostnames. Whatever upstream target that block
# uses for karman.hackclub.app, use the same here. A typical Nest entry looks
# like:
#
#     ww2explained.com, www.ww2explained.com {
#         reverse_proxy localhost:8080      # <-- match your existing karman.hackclub.app upstream
#     }
#
# TLS is automatic (Let's Encrypt) once Cloudflare DNS for ww2explained.com is
# "DNS only" (grey cloud). See DEPLOY.md.
#
# Reference: https://guides.hackclub.app/index.php/Subdomains_and_Custom_Domains

ww2explained.com, www.ww2explained.com {
	reverse_proxy localhost:8080
}
